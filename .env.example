# Sub2API image generation workstation.
# Docker production mode normally leaves these two VITE URLs empty so the browser calls the same Studio domain:
#   /api, /login, /v1/responses, /v1/images/*
# Nginx then proxies those requests to SUB2API_UPSTREAM.
VITE_SUB2API_BASE_URL=
VITE_SUB2API_GATEWAY_BASE_URL=
# Image route: auto uses /v1/responses for text-to-image and /v1/images/edits for reference/Mask flows.
# legacy is kept only for /v1/images/generations compatibility.
VITE_SUB2API_IMAGE_ROUTE=auto
VITE_SUB2API_RESPONSES_MODEL=gpt-5.5
VITE_SUB2API_RESPONSES_PARTIAL_IMAGES=2
# Optional comma-separated remote README case sources. Defaults match syber-gpt-image-2.
INSPIRATION_SOURCE_URLS=https://raw.githubusercontent.com/EvoLinkAI/awesome-gpt-image-2-prompts/main/README.md,https://raw.githubusercontent.com/YouMind-OpenLab/awesome-gpt-image-2/main/README.md
# Optional. Prefer the Studio domain login proxy so redirect returns to your studio domain.
VITE_SUB2API_LOGIN_URL=/login
# Optional. Empty means Studio reads /studio-api on the same domain.
VITE_STUDIO_HISTORY_BASE_URL=
# Optional. Left-top back link. Defaults to /.
VITE_STUDIO_BACK_URL=/
# Optional. Keep false for the open-source starter templates. Set true only after /studio-api/library is available.
VITE_STUDIO_LIBRARY_AUTH_REQUIRED=false
# Optional local dev proxy target. Lets http://127.0.0.1:5205 call /v1, /api, and /login without browser CORS.
VITE_DEV_SUB2API_PROXY_TARGET=https://sub2api.example.com

# Docker production deployment.
STUDIO_PORT=8080
# Existing Sub2API upstream. On a VPS where Sub2API runs on the host at 127.0.0.1:8080,
# keep the Docker default host gateway address below.
SUB2API_UPSTREAM=http://host.docker.internal:8080
STUDIO_NGINX_CLIENT_MAX_BODY_SIZE=120m
STUDIO_HISTORY_LIMIT=200
STUDIO_SESSION_NODE_LIMIT=80
# Optional protected library mount. Defaults to ./public.
STUDIO_LIBRARY_DIR=./public

# Optional local contract check. Do not commit real customer credentials.
SUB2API_BASE_URL=https://sub2api.example.com
SUB2API_EMAIL=
SUB2API_PASSWORD=

# Optional VPS history service.
STUDIO_HISTORY_HOST=127.0.0.1
STUDIO_HISTORY_PORT=8787
STUDIO_DATA_DIR=/var/lib/image-sub2api-studio
STUDIO_ALLOWED_ORIGINS=https://studio.example.com
